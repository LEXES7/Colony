{
  "name": "colony",
  "version": "0.1.0",
  "private": true,
  "description": "Colony — a local, security-first platform for managing a team of project agents",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @colony/server dev\" \"pnpm --filter @colony/web dev\"",
    "build": "pnpm --filter @colony/shared build && pnpm --filter @colony/web build && pnpm --filter @colony/server build",
    "start": "pnpm --filter @colony/server start",
    "check": "pnpm -r check && pnpm audit --prod || true",
    "desktop": "pnpm --filter @colony/web build && pnpm --filter @colony/desktop start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "playwright-core": "^1.61.1"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@anthropic-ai/claude-agent-sdk",
      "electron"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
